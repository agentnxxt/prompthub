    {
      "name": "Skill Level",
      "description": "SFIA responsibility levels 1-7, mapped to schema.org/DefinedTerm",
      "schemaType": "DefinedTerm",
      "categories": [
        {"code": "L1", "name": "Follow", "description": "Works under close direction. Uses standard procedures."},
        {"code": "L2", "name": "Assist", "description": "Works under routine direction. Uses standard practices."},
        {"code": "L3", "name": "Apply", "description": "Works under general direction. Uses discretion in resolving issues."},
        {"code": "L4", "name": "Enable", "description": "Works under general direction within a clear framework. Substantial personal responsibility."},
        {"code": "L5", "name": "Ensure, Advise", "description": "Works under broad direction. Full accountability for technical work."},
        {"code": "L6", "name": "Initiate, Influence", "description": "Has defined authority and accountability for significant area of work."},
        {"code": "L7", "name": "Set Strategy, Inspire", "description": "Leads at the highest organizational level. Sets strategy and inspires."}
